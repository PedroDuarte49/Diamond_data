<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/card_navy"
    android:padding="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvPlayerNameDialog"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Estadísticas de Jugador"
            android:textSize="20sp"
            android:textColor="@color/accent_orange"
            android:textStyle="bold"
            android:layout_marginBottom="16dp"/>

        <Button
            android:id="@+id/btnConfirmStats"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Confirmar Jugador"
            android:backgroundTint="@color/field_green"
            android:layout_marginTop="20dp"/>
    </LinearLayout>
</ScrollView>