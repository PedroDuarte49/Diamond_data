<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/card_navy"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Programar Partido"
        android:textSize="22sp"
        android:textColor="@color/accent_orange"
        android:textStyle="bold"
        android:layout_marginBottom="16dp"/>

    <EditText android:id="@+id/etGameOpponent" android:layout_width="match_parent" android:layout_height="wrap_content"
        android:hint="Equipo Rival (Ej. Red Sox)" android:textColor="@color/text_primary" android:textColorHint="@color/text_secondary" android:layout_marginBottom="12dp" android:backgroundTint="@color/accent_orange"/>

    <EditText android:id="@+id/etGameDate" android:layout_width="match_parent" android:layout_height="wrap_content"
        android:hint="Fecha (YYYY-MM-DD)" android:textColor="@color/text_primary" android:textColorHint="@color/text_secondary" android:layout_marginBottom="12dp" android:backgroundTint="@color/accent_orange"/>

    <EditText android:id="@+id/etGameLocation" android:layout_width="match_parent" android:layout_height="wrap_content"
        android:hint="Lugar / Estadio" android:textColor="@color/text_primary" android:textColorHint="@color/text_secondary" android:layout_marginBottom="12dp" android:backgroundTint="@color/accent_orange"/>

    <EditText android:id="@+id/etGameSeason" android:layout_width="match_parent" android:layout_height="wrap_content"
        android:hint="Temporada (Ej. 2026)" android:textColor="@color/text_primary" android:textColorHint="@color/text_secondary" android:layout_marginBottom="24dp" android:backgroundTint="@color/accent_orange"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSaveGame"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="GUARDAR PARTIDO"
        android:textStyle="bold"
        app:cornerRadius="8dp"
        app:backgroundTint="@color/accent_orange" />
</LinearLayout>