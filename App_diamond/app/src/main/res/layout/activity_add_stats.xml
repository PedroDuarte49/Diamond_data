<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/main_bg_gradient">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Box Score del Partido"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="24dp"/>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            app:cardBackgroundColor="@color/card_navy"
            app:cardCornerRadius="16dp"
            app:strokeWidth="2dp"
            app:strokeColor="@color/accent_orange">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:text="Pizarra por Inning (Carreras)"
                    android:textColor="@color/accent_orange"
                    android:textStyle="bold"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"/>

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scrollbars="none">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <EditText android:id="@+id/etInn1" android:layout_width="40dp" android:layout_height="wrap_content" android:hint="1º" android:inputType="number" android:textColor="@color/text_primary" android:textColorHint="@color/text_secondary" android:backgroundTint="@color/border_subtle" android:textAlignment="center"/>
                        <EditText android:id="@+id/etInn2" android:layout_width="40dp" android:layout_height="wrap_content" android:hint="2º" android:inputType="number" android:textColor="@color/text_primary" android:textColorHint="@color/text_secondary" android:backgroundTint="@color/border_subtle" android:textAlignment="center"/>
                        <EditText android:id="@+id/etInn3" android:layout_width="40dp" android:layout_height="wrap_content" android:hint="3º" android:inputType="number" android:textColor="@color/text_primary" android:textColorHint="@color/text_secondary" android:backgroundTint="@color/border_subtle" android:textAlignment="center"/>
                        <EditText android:id="@+id/etInn4" android:layout_width="40dp" android:layout_height="wrap_content" android:hint="4º" android:inputType="number" android:textColor="@color/text_primary" android:textColorHint="@color/text_secondary" android:backgroundTint="@color/border_subtle" android:textAlignment="center"/>
                        <EditText android:id="@+id/etInn5" android:layout_width="40dp" android:layout_height="wrap_content" android:hint="5º" android:inputType="number" android:textColor="@color/text_primary" android:textColorHint="@color/text_secondary" android:backgroundTint="@color/border_subtle" android:textAlignment="center"/>
                        <EditText android:id="@+id/etInn6" android:layout_width="40dp" android:layout_height="wrap_content" android:hint="6º" android:inputType="number" android:textColor="@color/text_primary" android:textColorHint="@color/text_secondary" android:backgroundTint="@color/border_subtle" android:textAlignment="center"/>
                        <EditText android:id="@+id/etInn7" android:layout_width="40dp" android:layout_height="wrap_content" android:hint="7º" android:inputType="number" android:textColor="@color/text_primary" android:textColorHint="@color/text_secondary" android:backgroundTint="@color/border_subtle" android:textAlignment="center"/>
                        <EditText android:id="@+id/etInn8" android:layout_width="40dp" android:layout_height="wrap_content" android:hint="8º" android:inputType="number" android:textColor="@color/text_primary" android:textColorHint="@color/text_secondary" android:backgroundTint="@color/border_subtle" android:textAlignment="center"/>
                        <EditText android:id="@+id/etInn9" android:layout_width="40dp" android:layout_height="wrap_content" android:hint="9º" android:inputType="number" android:textColor="@color/text_primary" android:textColorHint="@color/text_secondary" android:backgroundTint="@color/border_subtle" android:textAlignment="center"/>
                    </LinearLayout>
                </HorizontalScrollView>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:text="Estadísticas de Bateo / Defensa"
            android:textColor="@color/text_primary"
            android:textStyle="bold"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"/>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            app:cardBackgroundColor="@color/card_navy"
            app:cardCornerRadius="16dp"
            app:strokeWidth="1dp"
            app:strokeColor="@color/border_subtle">

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="4"
                android:padding="12dp">

                <EditText android:id="@+id/etFielderJ" android:layout_columnWeight="1" android:hint="J" android:inputType="number" android:textColor="@color/text_primary" android:textColorHint="@color/text_secondary" android:textSize="14sp"/>
                <EditText android:id="@+id/etFielderTB" android:layout_columnWeight="1" android:hint="TB" android:inputType="number" android:textColor="@color/text_primary" android:textColorHint="@color/text_secondary" android:textSize="14sp"/>
                <EditText android:id="@+id/etFielderC" android:layout_columnWeight="1" android:hint="C" android:inputType="number" android:textColor="@color/text_primary" android:textColorHint="@color/text_secondary" android:textSize="14sp"/>
                <EditText android:id="@+id/etFielderH" android:layout_columnWeight="1" android:hint="H" android:inputType="number" android:textColor="@color/text_primary" android:textColorHint="@color/text_secondary" android:textSize="14sp"/>

                <EditText android:id="@+id/etFielderH2" android:layout_columnWeight="1" android:hint="2B" android:inputType="number" android:textColor="@color/text_primary" android:textColorHint="@color/text_secondary" android:textSize="14sp"/>
                <EditText android:id="@+id/etFielderH3" android:layout_columnWeight="1" android:hint="3B" android:inputType="number" android:textColor="@color/text_primary" android:textColorHint="@color/text_secondary" android:textSize="14sp"/>
                <EditText android:id="@+id/etFielderH4" android:layout_columnWeight="1" android:hint="HR" android:inputType="number" android:textColor="@color/text_primary" android:textColorHint="@color/text_secondary" android:textSize="14sp"/>
                <EditText android:id="@+id/etFielderCIS" android:layout_columnWeight="1" android:hint="CI" android:inputType="number" android:textColor="@color/text_primary" android:textColorHint="@color/text_secondary" android:textSize="14sp"/>

                <EditText android:id="@+id/etFielderBB" android:layout_columnWeight="1" android:hint="BB" android:inputType="number" android:textColor="@color/text_primary" android:textColorHint="@color/text_secondary" android:textSize="14sp"/>
                <EditText android:id="@+id/etFielderBBI" android:layout_columnWeight="1" android:hint="BBI" android:inputType="number" android:textColor="@color/text_primary" android:textColorHint="@color/text_secondary" android:textSize="14sp"/>
                <EditText android:id="@+id/etFielderSO" android:layout_columnWeight="1" android:hint="SO" android:inputType="number" android:textColor="@color/text_primary" android:textColorHint="@color/text_secondary" android:textSize="14sp"/>
                <EditText android:id="@+id/etFielderBR" android:layout_columnWeight="1" android:hint="BR" android:inputType="number" android:textColor="@color/text_primary" android:textColorHint="@color/text_secondary" android:textSize="14sp"/>

                <EditText android:id="@+id/etFielderAR" android:layout_columnWeight="1" android:hint="AR" android:inputType="number" android:textColor="@color/text_primary" android:textColorHint="@color/text_secondary" android:textSize="14sp"/>
            </GridLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:text="Estadísticas de Pitcheo"
            android:textColor="@color/text_primary"
            android:textStyle="bold"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"/>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="32dp"
            app:cardBackgroundColor="@color/card_navy"
            app:cardCornerRadius="16dp"
            app:strokeWidth="1dp"
            app:strokeColor="@color/border_subtle">

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="4"
                android:padding="12dp">

                <EditText android:id="@+id/etPitcherG" android:layout_columnWeight="1" android:hint="G" android:inputType="number" android:textColor="@color/text_primary" android:textColorHint="@color/text_secondary" android:textSize="14sp"/>
                <EditText android:id="@+id/etPitcherP" android:layout_columnWeight="1" android:hint="P" android:inputType="number" android:textColor="@color/text_primary" android:textColorHint="@color/text_secondary" android:textSize="14sp"/>
                <EditText android:id="@+id/etPitcherJ" android:layout_columnWeight="1" android:hint="J" android:inputType="number" android:textColor="@color/text_primary" android:textColorHint="@color/text_secondary" android:textSize="14sp"/>
                <EditText android:id="@+id/etPitcherA" android:layout_columnWeight="1" android:hint="A" android:inputType="number" android:textColor="@color/text_primary" android:textColorHint="@color/text_secondary" android:textSize="14sp"/>

                <EditText android:id="@+id/etPitcherJC" android:layout_columnWeight="1" android:hint="JC" android:inputType="number" android:textColor="@color/text_primary" android:textColorHint="@color/text_secondary" android:textSize="14sp"/>
                <EditText android:id="@+id/etPitcherBL" android:layout_columnWeight="1" android:hint="BL" android:inputType="number" android:textColor="@color/text_primary" android:textColorHint="@color/text_secondary" android:textSize="14sp"/>
                <EditText android:id="@+id/etPitcherSV" android:layout_columnWeight="1" android:hint="SV" android:inputType="number" android:textColor="@color/text_primary" android:textColorHint="@color/text_secondary" android:textSize="14sp"/>
                <EditText android:id="@+id/etPitcherIL" android:layout_columnWeight="1" android:hint="IL" android:inputType="numberDecimal" android:textColor="@color/text_primary" android:textColorHint="@color/text_secondary" android:textSize="14sp"/>

                <EditText android:id="@+id/etPitcherH" android:layout_columnWeight="1" android:hint="H" android:inputType="number" android:textColor="@color/text_primary" android:textColorHint="@color/text_secondary" android:textSize="14sp"/>
                <EditText android:id="@+id/etPitcherCL" android:layout_columnWeight="1" android:hint="CL" android:inputType="number" android:textColor="@color/text_primary" android:textColorHint="@color/text_secondary" android:textSize="14sp"/>
                <EditText android:id="@+id/etPitcherSO" android:layout_columnWeight="1" android:hint="SO" android:inputType="number" android:textColor="@color/text_primary" android:textColorHint="@color/text_secondary" android:textSize="14sp"/>
            </GridLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSaveAll"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="GUARDAR BOX SCORE"
            android:textStyle="bold"
            app:backgroundTint="@color/accent_orange"
            app:cornerRadius="12dp"/>

    </LinearLayout>
</ScrollView>