<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/card_navy"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Nuevo Jugador"
        android:textSize="22sp"
        android:textColor="@color/accent_orange"
        android:textStyle="bold"
        android:layout_marginBottom="16dp"/>

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        app:boxStrokeColor="@color/accent_orange"
        android:textColorHint="@color/text_secondary">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etPlayerName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Nombre del Jugador"
            android:textColor="@color/text_primary"
            android:background="@color/card_navy"/>
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        app:boxStrokeColor="@color/accent_orange"
        android:textColorHint="@color/text_secondary">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etPlayerNumber"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="number"
            android:hint="Número de Camiseta (Dorsal)"
            android:textColor="@color/text_primary"
            android:background="@color/card_navy"/>
    </com.google.android.material.textfield.TextInputLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Rol en el equipo:"
        android:textColor="@color/text_secondary"
        android:layout_marginBottom="8dp"/>

    <RadioGroup
        android:id="@+id/rgPosition"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="24dp">

        <RadioButton
            android:id="@+id/rbFielder"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Bateador (F)"
            android:textColor="@color/text_primary"
            android:checked="true"
            android:buttonTint="@color/accent_orange"/>

        <RadioButton
            android:id="@+id/rbPitcher"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Lanzador (P)"
            android:textColor="@color/text_primary"
            android:buttonTint="@color/accent_orange"/>
    </RadioGroup>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSavePlayer"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="FICHAR JUGADOR"
        android:textStyle="bold"
        app:cornerRadius="8dp"
        app:backgroundTint="@color/accent_orange" />
</LinearLayout>